# --- required ---
# dashboard admin password
ADMIN_PASSWORD=change-me

# --- recommended ---
# session cookie signing secret (falls back to ADMIN_PASSWORD)
AUTH_SECRET=

# --- mail transport ---
# sandbox (default): capture emails to disk, no network — great for dev
# smtp: relay through SMTP_URL
# direct: deliver straight to recipient MX (needs port 25 egress + PTR)
SENDTHEN_MAIL_MODE=sandbox
# e.g. smtp://user:pass@smtp.eu.mailgun.org:587
SMTP_URL=
# EHLO hostname for direct mode
SENDTHEN_HOSTNAME=

# --- storage ---
DATABASE_PATH=./data/sendthen.db
SENDTHEN_OUTBOX_DIR=./data/outbox

# --- managed delivery (powers "Instance default" real sending) ---
# IAM user needs only ses:SendRawEmail
SENDTHEN_SES_ACCESS_KEY_ID=
SENDTHEN_SES_SECRET_ACCESS_KEY=
SENDTHEN_SES_REGION=

# --- plans & billing (hosted mode) ---
# set true to disable all plan limits (self-hosted default behavior)
SENDTHEN_UNLIMITED=
# Stripe payment link for the Pro upgrade button
STRIPE_PAYMENT_LINK=

# --- inbound email ---
# set a port (e.g. 25 or 2525) to run the built-in SMTP listener for MX receiving
SENDTHEN_SMTP_PORT=
# bearer token for POST /api/inbound/raw (defaults to a value derived from the instance secret)
SENDTHEN_INGEST_KEY=

# --- testing ---
# set to "verified" to make every domain DNS check pass (local dev only)
SENDTHEN_DNS_MOCK=
